### Friend related API endpoints ###
# List user's incoming friend requests (GET method with optional pagination as a query)
VITE_GET_INVITATION_LIST_URL=/api/v1/user/friends/requests/list/received

# List user's friends (GET method with optional pagination as a query)
VITE_GET_MY_FRIEND_LIST_URL=/api/v1/user/friends/list/myFriends

# List other user's friends (GET method with optional pagination as a query)
VITE_GET_FRIEND_LIST_URL=/api/v1/user/friends/list/friends/

# List other users (GET method with optional pagination as a query)
VITE_GET_USER_LIST_URL=/api/v1/user/friends/list/notFriends

# Accept a friend request (PUT request with the friend request's id as a parameter)
VITE_ACCEPT_FRIEND_REQUEST_URL=/api/v1/user/friends/requests/accept/

# Deny a friend request (PUT method with the friend request's id as a parameter)
VITE_DECLINE_FRIEND_REQUEST_URL=/api/v1/user/friends/requests/deny/

# Send a friend request (POST method with the user's id as the body)
VITE_SEND_FRIEND_REQUEST_URL=/api/v1/user/friends/requests/send

# Remove a friend (DELETE method with the friend's id as a query)
VITE_REMOVE_FRIEND_URL=/api/v1/user/friends/delete

# Get the relation between the logged user and another user (GET method with the other user's id as a parameter)
VITE_GET_USER_RELATION_URL=/api/v1/user/friends/relation/

# Get the number of friends of a user (GET method with the user's id as a parameter)
VITE_GET_FRIEND_NB_URL=/api/v1/user/friends/count/

#Get the number of incoming friend requests of the logged user (GET method)
VITE_GET_INVITATION_NB_URL=/api/v1/user/friends/requests/received/count/


